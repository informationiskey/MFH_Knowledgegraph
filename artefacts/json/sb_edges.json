  /* ============================================================
     SB – PHYSIK (SB‑01 bis SB‑03)
     ------------------------------------------------------------
     Semantische Bedeutung:
       - Diese drei Knoten bilden die physikalische Bedeutungsachse.
       - SB‑01 (Thermodynamik) ist die Grundlage aller energetischen
         Bedeutungen: Temperatur, Energie, Leistung.
       - SB‑02 (Energiebedarf) ist die abgeleitete Bedeutung, die
         beschreibt, wie viel Energie ein System benötigt.
       - SB‑03 (Leistungsbilanz) beschreibt die energetische
         Bewertung eines Systems (Verluste, Effizienz, Bilanzierung).
       - Die Kanten bilden eine logische Bedeutungs-Kaskade:
         Thermodynamik → Energiebedarf → Leistungsbilanz.
     ============================================================ */

  { "source": "SB-01", "type": "enables", "target": "SB-02" },
  { "source": "SB-02", "type": "enables", "target": "SB-03" },

