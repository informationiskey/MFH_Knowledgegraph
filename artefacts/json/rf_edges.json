[
  /* ============================================================
     RF – Bauordnung (LBO generisch → LBO Landesvarianten)
     ------------------------------------------------------------
     Zweck:
       - Die generische LBO (RF-86) wird durch die Landesbauordnungen
         der Bundesländer überschrieben.
     Semantik:
       - "overrides" = gültiger RF-Edge-Typ laut Taxonomie v2.1.
       - Normative Übersteuerung: Landesrecht > generisches Modell.
     ============================================================ */
  {
    "source": "RF-86",
    "type": "overrides",
    "target": "RF-86-BW"
  },
  {
    "source": "RF-86",
    "type": "overrides",
    "target": "RF-86-BY"
  },
  {
    "source": "RF-86",
    "type": "overrides",
    "target": "RF-86-HE"
  },

  /* ============================================================
     RF – Bauordnung (LBO Landesvarianten → VVTB Landesvarianten)
     ------------------------------------------------------------
     Zweck:
       - Die Landesbauordnung verweist auf die jeweilige VVTB.
     Semantik:
       - "delegates_to" = gültiger RF-Edge-Typ.
       - Delegation: LBO verweist auf technische Baubestimmungen.
     ============================================================ */
  {
    "source": "RF-86-BW",
    "type": "delegates_to",
    "target": "RF-87-BW"
  },
  {
    "source": "RF-86-BY",
    "type": "delegates_to",
    "target": "RF-87-BY"
  },
  {
    "source": "RF-86-HE",
    "type": "delegates_to",
    "target": "RF-87-HE"
  },

  /* ============================================================
     RF – Hygiene (Trinkwasser / DVGW)
     ------------------------------------------------------------
     Zweck:
       - TrinkwV (RF-70) verweist auf Legionellenprävention (W551).
       - W551 verweist auf Zirkulationsanforderungen (W553).
     Semantik:
       - "requires" = gültiger RF-Edge-Typ.
       - Normative Abhängigkeit: spätere Norm baut auf früherer auf.
     ============================================================ */
  {
    "source": "RF-70",
    "type": "requires",
    "target": "RF-71"
  },
  {
    "source": "RF-71",
    "type": "requires",
    "target": "RF-72"
  },

  /* ============================================================
     RF – GEG / Energie / Bilanzierung
     ------------------------------------------------------------
     Zweck:
       - RF-63 (DIN V 18599 Systembilanzierung) definiert die
         Methodik, die in RF-60/61/62 angewendet wird.
     Semantik:
       - "defines" = gültiger RF-Edge-Typ.
       - Methodische Grundlage → Anwendungsnormen.
     Hinweis:
       - Dies ersetzt die alten v2.0-Kanten "uses_method".
     ============================================================ */
  {
    "source": "RF-63",
    "type": "defines",
    "target": "RF-60"
  },
  {
    "source": "RF-63",
    "type": "defines",
    "target": "RF-61"
  },
  {
    "source": "RF-63",
    "type": "defines",
    "target": "RF-62"
  }
]

