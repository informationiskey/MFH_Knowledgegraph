[
  /* ============================================================
     ELEKTRO / VDE / NAV / TAB
     ------------------------------------------------------------
     Semantik:
       - TR-06 beschreibt die elektrische Anschlussleistung /
         Netzverträglichkeit.
       - Die RF-Knoten (77–85) definieren die regulatorischen
         Anforderungen aus VDE-AR-N 4100, NAV, DGUV etc.
       - "requires" = TR benötigt regulatorische Einhaltung.
     ============================================================ */

  { "source": "TR-06", "type": "requires", "target": "RF-78" },
  { "source": "TR-06", "type": "requires", "target": "RF-77" },
  { "source": "TR-06", "type": "requires", "target": "RF-80" },
  { "source": "TR-06", "type": "requires", "target": "RF-82" },
  { "source": "TR-06", "type": "requires", "target": "RF-83" },
  { "source": "TR-06", "type": "requires", "target": "RF-84" },
  { "source": "TR-06", "type": "requires", "target": "RF-85" },

  /* TR‑18‑R – regulatorische Leistungsgrenze
     ------------------------------------------------------------
     Mapping:
       - requires_VDE_upgrade → requires
       - subject_to → depends_on
       - activates → influences
     ============================================================ */

  { "source": "TR-18-R", "type": "requires",    "target": "RF-78" },
  { "source": "TR-18-R", "type": "depends_on",  "target": "RF-85" },
  { "source": "TR-18-R", "type": "influences",  "target": "RF-100" },

  /* TR‑18‑T – technische Leistungsgrenze
     ------------------------------------------------------------
     Mapping:
       - restricted_by → constrains
     ============================================================ */

  { "source": "TR-18-T", "type": "constrains", "target": "RF-78" },

  /* Leistungsstufen 12/21 kW
     ------------------------------------------------------------
     Mapping:
       - subject_to → depends_on
       - restricted_by → constrains
     ============================================================ */

  { "source": "TR-19", "type": "depends_on",  "target": "RF-85" },
  { "source": "TR-20", "type": "depends_on",  "target": "RF-85" },
  { "source": "TR-21", "type": "constrains",  "target": "RF-78" },

  /* ============================================================
     HYGIENE / TRINKWASSER
     ------------------------------------------------------------
     Semantik:
       - enforced_by = regulatorische Pflicht (bleibt gültig)
       - regulated_by = normative Steuerung (bleibt gültig)
       - triggers_legionellenprüfung → influences
     ============================================================ */

  { "source": "TR-02", "type": "enforced_by", "target": "RF-70" },
  { "source": "TR-02", "type": "enforced_by", "target": "RF-71" },

  { "source": "TR-03", "type": "regulated_by", "target": "RF-71" },
  { "source": "TR-03", "type": "regulated_by", "target": "RF-72" },

  { "source": "TR-22", "type": "influences", "target": "RF-72" },

  /* ============================================================
     GEG / BILANZIERUNG
     ------------------------------------------------------------
     Mapping:
       - requires_JAZ → depends_on
       - affects_WW_Bilanz → influences
       - evaluated_by bleibt gültig
     ============================================================ */

  { "source": "TR-04b", "type": "depends_on", "target": "RF-61" },
  { "source": "TR-03",  "type": "influences", "target": "RF-62" },

  { "source": "TR-13", "type": "evaluated_by", "target": "RF-60" },
  { "source": "TR-13", "type": "evaluated_by", "target": "RF-61" },
  { "source": "TR-13", "type": "evaluated_by", "target": "RF-63" },

  { "source": "TR-14", "type": "evaluated_by", "target": "RF-60" },
  { "source": "TR-14", "type": "evaluated_by", "target": "RF-61" },
  { "source": "TR-14", "type": "evaluated_by", "target": "RF-63" },

  { "source": "TR-05", "type": "evaluated_by", "target": "RF-63" },
  { "source": "TR-11", "type": "evaluated_by", "target": "RF-63" },

  /* ============================================================
     BAUORDNUNG / SCHALL / AUFSTELLFLÄCHEN
     ------------------------------------------------------------
     Mapping:
       - requires_schallgrenze → requires
       - requires_aufstellfläche → requires
     ============================================================ */

  { "source": "TR-07", "type": "requires", "target": "RF-86" },
  { "source": "TR-08", "type": "requires", "target": "RF-86" },

  /* ============================================================
     FÖRDERLOGIK (BEG / BAFA / KfW)
     ------------------------------------------------------------
     Semantik:
       - relevant_for bleibt gültig
       - TR-00a/b beeinflussen Förderfähigkeit
     ============================================================ */

  { "source": "TR-00a", "type": "relevant_for", "target": "RF-90" },
  { "source": "TR-00a", "type": "relevant_for", "target": "RF-91" },
  { "source": "TR-00a", "type": "relevant_for", "target": "RF-92" },

  { "source": "TR-00b", "type": "relevant_for", "target": "RF-90" },
