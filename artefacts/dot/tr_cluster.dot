    "TR-05" -> "EffBew"  [label="creates_bilanzkonflikt"];
    "TR-11" -> "EffBew"  [label="redefines"];

    /* DLE‑Pfad */
    "TR-15" -> "TR-00b" [label="modulates"];
    "TR-16" -> "TR-00b" [label="modulates"];
    "TR-17" -> "TR-00b" [label="modulates"];

    "TR-02" -> "TR-15" [label="conflicts_with"];
    "TR-02" -> "TR-16" [label="conflicts_with"];
    "TR-02" -> "TR-17" [label="conflicts_with"];

    "TR-15" -> "TR-03" [label="blocks"];
    "TR-16" -> "TR-03" [label="blocks"];
    "TR-17" -> "TR-03" [label="blocks"];

