    "TR-13" -> "TR-11" [label="reduces_losses"];
    "TR-13" -> "TR-01" [label="reduces_temp"];
    "TR-13" -> "WPEff" [label="enables"];

    "TR-14" -> "TR-11" [label="reduces_losses"];
    "TR-14" -> "TR-01" [label="reduces_temp"];
