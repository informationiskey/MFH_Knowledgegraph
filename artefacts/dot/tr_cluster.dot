/* ============================================================
   CLUSTER: TR – Technische Realität (v2.1, vollständiger Freeze)
   ============================================================ */

subgraph cluster_TR {
    label="Ebene TR – Technische Realität (v2.1)";
    color="#b0c4de";
    style="rounded";
    fontname="Arial";

