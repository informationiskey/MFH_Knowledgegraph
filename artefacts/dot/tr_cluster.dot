    "TR-16" -> "TR-18-R" [label="exceeds_regulatory_threshold"];
    "TR-17" -> "TR-18-R" [label="exceeds_regulatory_threshold"];

    "TR-15" -> "TR-18-T" [label="exceeds_technical_threshold"];
    "TR-16" -> "TR-18-T" [label="exceeds_technical_threshold"];
    "TR-17" -> "TR-18-T" [label="exceeds_technical_threshold"];

    /* TR‑18‑T → technische Folgen */
    "TR-18-T" -> "TR-01" [label="reduces_heating_capacity"];
    "TR-18-T" -> "TR-02" [label="prevents_60C_hygiene"];
    "TR-18-T" -> "TR-22" [label="prevents_21C"];
    "TR-18-T" -> "TR-25" [label="enables_mietminderung"];

    /* Leistungsstufen 12/21 kW */
    "TR-15" -> "TR-19" [label="exceeds_threshold"];
    "TR-16" -> "TR-19" [label="exceeds_threshold"];
    "TR-17" -> "TR-19" [label="exceeds_threshold"];

    "TR-15" -> "TR-20" [label="may_exceed_threshold"];
    "TR-16" -> "TR-20" [label="likely_exceeds_threshold"];
    "TR-17" -> "TR-20" [label="exceeds_threshold"];

    "TR-19" -> "TR-06" [label="requires_registration"];
    "TR-20" -> "TR-06" [label="requires_approval"];

    "TR-19" -> "LM" [label="increases_load"];
    "TR-20" -> "LM" [label="critical_load"];

    /* Einphasenbegrenzung */
    "TR-21" -> "TR-15" [label="prerequisite_for"];
    "TR-21" -> "TR-16" [label="prerequisite_for"];
    "TR-21" -> "TR-17" [label="prerequisite_for"];

    "TR-21" -> "TR-06" [label="increases_complexity"];
    "TR-21" -> "TR-07" [label="increases_installation_effort"];

    /* Mietrechtliche TR‑Knoten */
    "TR-22" -> "TR-01" [label="defines_minimum"];
    "TR-22" -> "TR-02" [label="defines_minimum"];
    "TR-22" -> "TR-03" [label="defines_minimum"];
    "TR-22" -> "TR-08" [label="defines_limit"];

    "TR-23" -> "LM"     [label="cost_sensitive"];
    "TR-23" -> "WPsys"  [label="cost_sensitive"];
    "TR-23" -> "TR-04a" [label="cost_sensitive"];
    "TR-23" -> "TR-04b" [label="cost_sensitive"];

