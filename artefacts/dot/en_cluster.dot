/* ============================================================
   CLUSTER: EN – Enabler (v21, englische Tags, deutsche Labels)
   ============================================================ */

subgraph cluster_EN {
    label="Ebene EN – Enabler (v21)";
    color="#cccccc";
    style="rounded";
    fontname="Arial";

    node [shape=box, style=filled, fillcolor="#f2f2f2", fontname="Arial"];

    "EN-01" [label="EN‑01\nAlternative Nachweisführung\nTags: alternative_path, systemic"];
    "EN-02" [label="EN‑02\nBestandsschutz\nTags: deviation, legal"];
    "EN-03" [label="EN‑03\nRisikobasierter Brandschutz\nTags: risk, deviation"];
    "EN-04" [label="EN‑04\nTechnische Kompensationsmaßnahmen\nTags: compensation, technical"];
    "EN-05" [label="EN‑05\nBetriebliche Kompensationsmaßnahmen\nTags: compensation, operational"];
    "EN-06" [label="EN‑06\nSystemische Bewertung\nTags: systemic, evaluation"];
    "EN-06b" [label="EN‑06b\nSystemischer GEG‑Nachweis\nTags: systemic, alternative_path, balancing"];
    "EN-07" [label="EN‑07\nAbweichung nach LBO\nTags: deviation, building_code"];
    "EN-08" [label="EN‑08\nMietrechtliche Anerkennung Strommangellage\nTags: tenancy_law, legal"];
    "EN-09" [label="EN‑09\nErweiterte Betreiberverantwortung\nTags: operational, deviation"];
    "EN-10" [label="EN‑10\nWirtschaftlichkeitsabwägung\nTags: economic, deviation"];
    "EN-11" [label="EN‑11\nTechnische Gleichwertigkeit\nTags: alternative_path, technical"];
    "EN-12" [label="EN‑12\nPrognosebasierte Bewertung\nTags: forecast, systemic"];
}

/* ============================================================
   RF‑ZIEL‑NODES (automatisch aus EN‑Edges abgeleitet)
   ============================================================ */

subgraph cluster_RF_targets {
    label="RF‑Zielknoten (durch EN beeinflusst)";
    color="#dddddd";
    style="rounded";
    fontname="Arial";

    node [shape=box, style=filled, fillcolor="#ffffff", fontname="Arial"];

    "RF-60"  [label="RF‑60\nGEG – Primärenergie"];
    "RF-61"  [label="RF‑61\nGEG – Endenergie"];
    "RF-63"  [label="RF‑63\nGEG – Systembilanz"];
    "RF-70"  [label="RF‑70\nLBO – Brandschutzgrundsatz"];
    "RF-71"  [label="RF‑71\nLBO – Abweichung möglich"];
    "RF-72"  [label="RF‑72\nLBO – Kompensationsmaßnahmen"];
    "RF-86"  [label="RF‑86\nLandesrecht – Abweichung"];
    "RF-87-BW" [label="RF‑87‑BW\nVVTB BW – Brandschutz"];
    "RF-87-BY" [label="RF‑87‑BY\nVVTB BY – Brandschutz"];
    "RF-87-HE" [label="RF‑87‑HE\nVVTB HE – Brandschutz"];
    "RF-100" [label="RF‑100\nMietrecht – Wirtschaftlichkeit"];
    "RF-101" [label="RF‑101\nMietrecht – Betreiberpflichten"];
    "RF-102" [label="RF‑102\nGEG – Wirtschaftlichkeitsgrenze"];
}

