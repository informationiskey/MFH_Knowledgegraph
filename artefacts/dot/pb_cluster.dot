/* ============================================================
   CLUSTER: PB – Politische Blockaden (v2.1, vollständiger Freeze)
   ============================================================ */

subgraph cluster_PB {
    label="Ebene PB – Politische Blockaden (v2.1)";
    color="#ffcccc";
    style="rounded";
    fontname="Arial";

    node [shape=box, style=filled, fillcolor="#ffecec", fontname="Arial"];

    /* ============================
       PB‑NODES (vollständig)
       ============================ */

    "PB-01" [label="PB‑01\nGEG‑65%-Regel vs. Systembilanz"];
    "PB-02" [label="PB‑02\nLBO‑Schall vs. WP‑Außenaufstellung"];
    "PB-03" [label="PB‑03\nMietrecht vs. Lastmanagement"];
    "PB-04" [label="PB‑04\nDVGW‑Hygiene vs. WP‑Temperaturen"];
    "PB-05" [label="PB‑05\nVDE‑4100 vs. DLE‑Umrüstung"];
    "PB-06" [label="PB‑06\nNetzanschlussleistung vs. WP‑Systeme"];
    "PB-07" [label="PB‑07\nFörderlogik vs. Wirtschaftlichkeit im MFH"];
}

